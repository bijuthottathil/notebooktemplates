# ─────────────────────────────────────────────────────────────────────────────
# etl-template1 credential configuration
# Replaces dbutils.widgets for credential settings — edit before running nb_00.
#
# DO NOT commit this file with real secrets to source control.
# Add .env to .gitignore in production.
# ─────────────────────────────────────────────────────────────────────────────

# Unity Catalog storage credential name
CREDENTIAL_NAME=adls_sp_credential

# Azure Key Vault-backed Databricks secret scope
CLIENT_ID_SECRET_SCOPE=kv-databricks

# Secret key names within the scope
CLIENT_ID_SECRET_KEY=sp-client-id
CLIENT_SECRET_KEY=sp-client-secret
TENANT_ID_SECRET_KEY=sp-tenant-id
